{
  "name": "pi-tldraw",
  "version": "0.1.0",
  "type": "module",
  "description": "Pi extension that opens and persists a local tldraw MCP canvas.",
  "license": "MIT",
  "author": {
    "name": "Zeebee Siwiec",
    "email": "byniutek@gmail.com",
    "url": "https://github.com/zeebeeCoder"
  },
  "contributors": [
    {
      "name": "Zeebee Siwiec",
      "email": "byniutek@gmail.com",
      "url": "https://github.com/zeebeeCoder"
    }
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "mcp",
    "mcp-app",
    "tldraw"
  ],
  "files": [
    "src/",
    "static/",
    "mcp-app/",
    "README.md",
    "tsconfig.json",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typebox": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/zeebeeCoder/pi-tldraw.git"
  },
  "bugs": {
    "url": "https://github.com/zeebeeCoder/pi-tldraw/issues"
  },
  "homepage": "https://github.com/zeebeeCoder/pi-tldraw#readme"
